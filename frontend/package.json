{
    "name":  "frontend",
    "private":  true,
    "version":  "0.0.0",
    "type":  "module",
    "scripts":  {
                    "backup":  "node -e \"require(\u0027../recovery-system.js\u0027).createBackup()\"",
                    "deploy":  "npm run build \u0026\u0026 npm run commit \u0026\u0026 npm run push",
                    "push":  "git push origin main",
                    "format":  "prettier --write \"src/**/*.{js,jsx}\"",
                    "build":  "vite build",
                    "secure-check":  "npm audit",
                    "lint":  "eslint src --ext js,jsx",
                    "verify":  "node ../architecture-verify.js",
                    "auto-commit":  "powershell -File ../auto-commit.ps1",
                    "dev":  "vite",
                    "recover":  "node ../recovery-system.js",
                    "preview":  "vite preview",
                    "commit":  "git add . \u0026\u0026 git commit -m"
                },
